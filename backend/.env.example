# Copia este archivo como .env en el servidor.
# No subas .env real a GitHub.

APP_NAME="RA Revisiones Automaticas"
APP_ENV=development

# Cambia el host según dónde corra la API.
# Si la API corre en el mismo NAS que Docker/Postgres, puedes usar 127.0.0.1 y puerto 15432.
# Si la API corre en otro equipo dentro de la VPN, usa la IP privada del NAS.
DB_HOST=127.0.0.1
DB_PORT=15432
DB_NAME=BaseAviaRockets
DB_USER=IronMan
DB_PASSWORD=CAMBIAR_EN_SERVIDOR

# Cambia este secreto por uno largo y aleatorio.
JWT_SECRET=CAMBIAR_POR_SECRETO_LARGO
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=720

# Orígenes autorizados para llamar la API desde navegador.
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://joacoaviles.github.io,https://ra.aviarockets.cl
